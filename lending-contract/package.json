{
  "name": "bitlend-contract",
  "version": "1.0.0",
  "description": "BitLend Lending Protocol for OP_NET Testnet",
  "scripts": {
    "build":        "tsc --noEmit",
    "compile":      "asc LendingProtocol.ts --outFile LendingProtocol.wasm --optimize",
    "deploy":       "ts-node deploy.ts",
    "deploy:cli":   "opnet deploy --contract LendingProtocol.wasm --network testnet --feeRate 10",
    "check":        "npm run"
  },
  "dependencies": {
    "opnet":                   "latest",
    "@btc-vision/transaction": "latest",
    "@btc-vision/bitcoin":     "latest"
  },
  "devDependencies": {
    "assemblyscript":  "latest",
    "typescript":      "latest",
    "ts-node":         "latest",
    "@types/node":     "latest"
  }
}